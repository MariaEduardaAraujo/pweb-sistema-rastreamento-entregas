<h1>Entrega #<%= entrega.id %></h1>

<div class="detalhesEntrega">
  <p>Descrição: <%= entrega.descricao %></p>
  <p>Origem: <%= entrega.origem %></p>
  <p>Destino: <%= entrega.destino %></p>
  <p>Status: <span class="badge badge-<%= entrega.status.toUpperCase() %>"><%= entrega.status %></span></p>
  <p>Motorista: <%= entrega.motorista?.nome ?? 'Sem motorista' %></p>
</div>

<h2>Histórico de Eventos</h2>

<table>
  <thead>
    <tr>
      <th>Data</th><th>Hora</th><th>Descrição</th>
    </tr>
  </thead>
  <tbody>
    <% entrega.eventos.forEach(evento => { %>
      <tr>
        <td><%= new Date(evento.createdAt).toLocaleDateString('pt-BR') %></td>
        <td><%= new Date(evento.createdAt).toLocaleTimeString('pt-BR') %></td>
        <td><%= evento.descricao %></td>
      </tr>
    <% }) %>
  </tbody>
</table>

<div class="botoesDetalhes">
  <form id="botaoDetalhesAvancar" method="POST" action="/painel/entregas/<%= entrega.id %>/status">
    <input type="hidden" name="_method" value="PUT">
    <button type="submit">Avançar Status</button>
  </form>

  <form id="botaoDetalhesCancelar" method="POST" action="/painel/entregas/<%= entrega.id %>/cancelar">
    <input type="hidden" name="_method" value="DELETE">
    <button type="submit">Cancelar Entrega</button>
  </form>
</div>