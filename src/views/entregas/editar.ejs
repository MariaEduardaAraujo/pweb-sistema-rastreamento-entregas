<h1>Editar Entrega</h1>

<form method="POST" action="/painel/entregas/<%= entrega.id %>?_method=PUT">

  <label>Descrição</label>
  <input type="text" name="descricao" value="<%= old.descricao ?? entrega.descricao %>">
  <% if(erros.descricao) { %><span class="erro"><%= erros.descricao %></span><% } %>

  <label>Origem</label>
  <input type="text" name="origem" value="<%= old.origem ?? entrega.origem %>">
  <% if(erros.origem) { %><span class="erro"><%= erros.origem %></span><% } %>

  <label>Destino</label>
  <input type="text" name="destino" value="<%= old.destino ?? entrega.destino %>">
  <% if(erros.destino) { %><span class="erro"><%= erros.destino %></span><% } %>

  <label>Motorista</label>
  <select name="motoristaId">
    <option value="">Sem motorista</option>
    <% motoristas.forEach(m => { %>
      <option value="<%= m.id %>"
        <%= (old.motoristaId ?? entrega.motoristaId) == m.id ? 'selected' : '' %>>
        <%= m.nome %>
      </option>
    <% }) %>
  </select>

  <button type="submit">Salvar</button>
  <a href="/painel/entregas/<%= entrega.id %>">Cancelar</a>

</form>