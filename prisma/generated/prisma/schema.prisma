generator client {
  provider        = "prisma-client-js"
  output          = "./generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model Motorista {
  id           Int       @id @default(autoincrement())
  nome         String
  cpf          String    @unique
  placaVeiculo String
  entregas     Entrega[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("motorista")
}

enum StatusEntrega {
  CRIADA
  EM_TRANSITO
  ENTREGUE
  CANCELADA
}

model Entrega {
  id          Int             @id @default(autoincrement())
  descricao   String
  origem      String
  destino     String
  status      StatusEntrega   @default(CRIADA)
  motorista   Motorista?      @relation(fields: [motoristaId], references: [id])
  motoristaId Int
  eventos     EventoEntrega[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("entrega")
}

model EventoEntrega {
  id        Int      @id @default(autoincrement())
  descricao String
  entrega   Entrega  @relation(fields: [entregaId], references: [id], onDelete: Cascade)
  entregaId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("eventos")
}
